# Supabase (required for waitlist)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Anthropic Claude (optional — mock fallback if unset)
ANTHROPIC_API_KEY=

# Voice provider — set to "elevenlabs" (default) or "fish" to switch providers
# Switching this value + redeploying is all that's needed to change providers.
VOICE_PROVIDER=elevenlabs

# ElevenLabs TTS (used when VOICE_PROVIDER=elevenlabs)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Fish Audio TTS (used when VOICE_PROVIDER=fish)
# Get API key at https://fish.audio/settings/api
FISH_AUDIO_API_KEY=

# HeyGen Video Avatar (optional — mock fallback if unset)
HEYGEN_API_KEY=

# Stripe Payments (optional — mock checkout if unset)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=
NEXT_PUBLIC_STRIPE_ELITE_PRICE_ID=
